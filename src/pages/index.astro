---
/**
 * index.astro — Home page (PURE ASTRO + HeroCarousel island)
 *
 * Pattern:
 *   1. Fetch ALL data in frontmatter using direct fetch() to backend
 *   2. Transform settings array → key-value map
 *   3. Render as pure Astro HTML — NO React for static content
 *   4. Only the HeroCarousel is a React island (needs auto-slide timer)
 *   5. Use inline SVGs instead of lucide-react icons
 *   6. Use `class` instead of `className`
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroCarousel from '@/islands/HeroCarousel';
import { buildOrganizationJsonLd, buildBreadcrumbJsonLd, stripHtml, truncateText } from '@/lib/seo';
import { getStandardizedDisplayPrice, getStandardizedDisplayTitle } from '@/lib/pricing';

const siteUrl = import.meta.env.SITE;
const API_BASE = 'http://127.0.0.1:8000/api';

// --- Data Fetching (runs at build time) ---
let heroSlides: any[] = [];
let categories: any[] = [];
let trendingItems: any[] = [];
let settings: Record<string, string> = {};

try {
  const [slidesRes, categoriesRes, trendingRes, settingsRes] = await Promise.all([
    fetch(`${API_BASE}/v1/hero-slides`).then(r => r.ok ? r.json() : []),
    fetch(`${API_BASE}/v1/product-categories`).then(r => r.ok ? r.json() : []),
    fetch(`${API_BASE}/v1/products/featured`).then(r => r.ok ? r.json() : []),
    fetch(`${API_BASE}/v1/settings`).then(r => r.ok ? r.json() : []),
  ]);
  heroSlides = slidesRes || [];
  categories = (categoriesRes || []).slice(0, 4);
  trendingItems = trendingRes || [];
  const settingsMap: Record<string, string> = {};
  (settingsRes || []).forEach((s: any) => {
    settingsMap[s.key] = s.value;
  });
  settings = settingsMap;
} catch (err) {
  console.error('Failed to load homepage data at build time:', err);
}

const t = (key: string, def: string) => settings[key] || def;

const weldingPrimaryImage = t("home_welding_image", t("home_gallery_1", "/images/welding.jpg"));
const weldingSecondaryImage = t("home_welding_secondary_image", t("home_gallery_5", "/images/workshop.jpg"));
const weldingServiceSlug = (t("home_welding_service_slug", "custom-fabrication") || "custom-fabrication").trim();
const weldingServicePath = `/services/${encodeURIComponent(weldingServiceSlug || "custom-fabrication")}`;

const title = 'Midia M Metal | Commercial Kitchen Ventilation & Fabrication';
const description = 'Specialist in commercial kitchen ventilation, stainless steel fabrication, and canopy installation across the UK.';
const image = '/logo.png';

const organizationJsonLd = buildOrganizationJsonLd({
  name: 'Midia M Metal',
  url: `${siteUrl}/`,
  logo: `${siteUrl}/logo.png`,
  email: 'info@midia-metal.com',
  telephone: '+44 123 456 7890',
  sameAs: [],
});

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Midia M Metal',
  url: `${siteUrl}/`,
  description: truncateText(stripHtml(description)),
};

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: 'Home', url: `${siteUrl}/` },
]);
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  canonicalPath="/"
  structuredData={[organizationJsonLd, websiteJsonLd, breadcrumbJsonLd]}
>
  <div class="min-h-screen bg-[#f2f3f5]">
    <!-- Hero Carousel (React island — needs auto-slide timer) -->
    <section class="container mx-auto px-4 lg:px-8 pt-4 md:pt-6">
      <HeroCarousel slides={heroSlides} client:load />
    </section>

    <!-- Features Bar -->
    <section class="bg-[#f2f3f5]">
      <div class="container mx-auto px-4 lg:px-8 py-7 md:py-10">
        <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-8">
          <!-- Feature 1: Gift -->
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 md:h-8 md:w-8 flex-shrink-0 text-[#7a8293]"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
            <div class="leading-tight">
              <p class="font-sans text-[13px] md:text-[17px] font-semibold text-[#15264b]">{t("home_reward_title", "Commercial-grade fabrication")}</p>
              <p class="mt-1 text-[10px] md:text-xs text-[#8b93a4]">{t("home_reward_desc", "Built for demanding kitchen and ventilation environments.")}</p>
            </div>
          </div>
          <!-- Feature 2: CirclePercent -->
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 md:h-8 md:w-8 flex-shrink-0 text-[#7a8293]"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="M9 9h.01"/><path d="M15 15h.01"/></svg>
            <div class="leading-tight">
              <p class="font-sans text-[13px] md:text-[17px] font-semibold text-[#15264b]">{t("home_discount_title", "Fast quote turnaround")}</p>
              <p class="mt-1 text-[10px] md:text-xs text-[#8b93a4]">{t("home_discount_desc", "Clear commercial pricing and lead times for every enquiry.")}</p>
            </div>
          </div>
          <!-- Feature 3: ShoppingBag -->
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 md:h-8 md:w-8 flex-shrink-0 text-[#7a8293]"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <div class="leading-tight">
              <p class="font-sans text-[13px] md:text-[17px] font-semibold text-[#15264b]">{t("home_shipping_title", "UK-wide delivery")}</p>
              <p class="mt-1 text-[10px] md:text-xs text-[#8b93a4]">{t("home_shipping_desc", "Reliable dispatch for stocked products and fabricated components.")}</p>
            </div>
          </div>
          <!-- Feature 4: WalletMinimal -->
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 md:h-8 md:w-8 flex-shrink-0 text-[#7a8293]"><path d="M17 14h.01"/><path d="M7 7h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14"/></svg>
            <div class="leading-tight">
              <p class="font-sans text-[13px] md:text-[17px] font-semibold text-[#15264b]">{t("home_prices_title", "Installation support")}</p>
              <p class="mt-1 text-[10px] md:text-xs text-[#8b93a4]">{t("home_prices_desc", "Supply, fabrication, installation, and aftercare in one workflow.")}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Metal Welding -->
    <section class="container mx-auto px-4 lg:px-8 pt-4 md:pt-8 pb-8 md:pb-12">
      <p class="text-center text-[10px] font-bold tracking-[0.2em] text-muted-foreground uppercase mb-2">
        {t("home_fabrication_section_label", "OUR FABRICATION")}
      </p>
      <h2 class="text-[30px] md:text-[40px] leading-tight font-semibold text-[#10275c] font-sans text-center mb-6 md:mb-8">
        {t("home_fabrication_section_title", "Fabrication")}
      </h2>
      <div class="grid grid-cols-1 xl:grid-cols-[0.9fr_1.1fr] gap-4 md:gap-6">
        <div class="bg-primary p-6 md:p-10 flex flex-col justify-between min-h-[320px] md:min-h-[440px]">
          <div>
            <p class="text-[10px] font-bold tracking-[0.2em] text-white/70 uppercase mb-3 md:mb-4">
              {t("home_welding_label", "Metal welding services")}
            </p>
            <h2 class="font-sans text-[34px] md:text-[50px] leading-[0.95] font-semibold text-white mb-5 md:mb-6">
              {t("home_welding_title", "Metal welding & bespoke fabrication")}
            </h2>
            <p class="text-sm md:text-[15px] leading-6 md:leading-7 text-white/80 max-w-xl">
              {t(
                "home_welding_desc",
                "Custom stainless steel builds, repair work, on-site modifications, and workshop welding for commercial kitchens, industrial spaces, and made-to-order metalwork."
              )}
            </p>
          </div>

          <div class="flex flex-wrap gap-3 pt-8">
            <a
              href="/get-a-quote"
              class="inline-flex items-center justify-center px-6 md:px-7 py-3 bg-orange text-white text-xs md:text-sm font-semibold hover:bg-orange-hover transition-colors"
            >
              {t("home_welding_primary_cta", "Request Welding Quote")}
            </a>
            <a
              href={weldingServicePath}
              class="inline-flex items-center justify-center px-6 md:px-7 py-3 border border-white/30 text-white text-xs md:text-sm font-semibold hover:bg-white hover:text-primary transition-colors"
            >
              {t("home_welding_secondary_cta", "View More")}
            </a>
          </div>
        </div>

        <div class="relative overflow-hidden bg-[#e8edf1] min-h-[320px] md:min-h-[440px]">
          <img
            src={weldingPrimaryImage}
            alt={t("home_welding_image_alt", "Metal welding and fabrication work")}
            loading="eager" decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-[#10275c]/18 via-[#10275c]/6 to-[#10275c]/35" />

          <div class="absolute left-4 right-4 bottom-4 md:left-6 md:right-auto md:bottom-6 flex items-end gap-3 md:gap-4">
            <div class="hidden md:block w-[188px] h-[144px] overflow-hidden border border-white/30 shadow-[0_12px_30px_rgba(16,39,92,0.16)]">
              <img
                src={weldingSecondaryImage}
                alt={t("home_welding_secondary_image_alt", "Workshop fabrication")}
                loading="lazy" decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="bg-[#f4f6f8] border border-[#d4dce6] px-4 md:px-5 py-4 md:py-5 max-w-[340px]">
              <p class="text-[10px] font-bold tracking-[0.18em] text-[#7b879a] uppercase mb-2">
                {t("home_welding_card_label", "Workshop + site support")}
              </p>
              <p class="font-sans text-[18px] md:text-[22px] leading-[1.05] font-semibold text-primary mb-2">
                {t("home_welding_card_title", "From fabrication bench to final install")}
              </p>
              <p class="text-[12px] md:text-[13px] leading-5 text-[#6f7e9a]">
                {t("home_welding_card_desc", "Built for projects that need custom metalwork, fast adjustments, and practical welding support on the job.")}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="container mx-auto px-4 lg:px-8 pt-4 md:pt-8 pb-8 md:pb-12">
      <p class="text-center text-[10px] font-bold tracking-[0.2em] text-muted-foreground uppercase mb-2">
        {t("home_categories_section_label", "OUR CATEGORIES")}
      </p>
      <h2 class="text-[30px] md:text-[40px] leading-tight font-semibold text-[#10275c] font-sans text-center mb-6 md:mb-8">
        {t("home_categories_section_title", "Product Categories")}
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {categories.map((cat) => (
          <a
            href={`/shop/category/${cat.slug}`}
            class="relative block overflow-hidden group"
          >
            <img src={cat.image} alt={cat.name} loading="lazy" decoding="async" class="w-full h-[124px] sm:h-[150px] md:h-[260px] object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/10 to-transparent flex items-end p-3 md:p-5">
              <p class="text-white text-[13px] sm:text-[16px] md:text-[22px] leading-tight font-semibold">{cat.name}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Trending Items -->
    <section class="container mx-auto px-4 lg:px-8 py-10 md:py-20">
      <p class="text-center text-[10px] font-bold tracking-[0.2em] text-muted-foreground uppercase mb-2">{t("home_catalog_label", "OUR CATALOG")}</p>
      <h2 class="text-center text-[44px] leading-none md:text-[38px] font-semibold text-[#10275c] mb-8 md:mb-12 font-sans">{t("home_trending_title", "Best-selling products")}</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {trendingItems.map((item) => (
          <a href={`/shop/${item.slug}`} class="product-card">
            <div class="relative bg-[#e9ecef] overflow-hidden mb-3 md:mb-4">
              {item.badge && (
                <span class="absolute top-2 left-2 z-10 bg-orange text-accent-foreground text-[11px] font-bold px-2 py-0.5">
                  {item.badge}
                </span>
              )}
              <img src={item.image} alt={item.name} loading="lazy" decoding="async" class="w-full aspect-square object-cover" />
            </div>
            <h3 class="font-sans text-[16px] md:text-[20px] leading-tight md:leading-7 font-semibold text-orange">{getStandardizedDisplayTitle(item)}</h3>
            <div class="flex items-center gap-2 mt-1 flex-wrap">
              {item.old_price && (
                <span class="text-[16px] md:text-[20px] text-muted-foreground line-through">{item.old_price}</span>
              )}
              <span class="text-[14px] md:text-[20px] font-medium text-[#15264b]/75">
                {getStandardizedDisplayPrice(item)}
              </span>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8 md:mt-10">
        <a href="/shop" class="inline-flex items-center justify-center px-8 md:px-10 py-3 md:py-4 bg-primary text-primary-foreground font-semibold text-xs md:text-sm hover:bg-navy-light transition-colors">
          {t("home_view_more_label", "View More Products")}
        </a>
      </div>
    </section>

    <!-- CTA Banners -->
    <section class="container mx-auto px-4 lg:px-8 py-10 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="relative overflow-hidden min-h-[200px] md:h-[240px] bg-gradient-to-r from-[#eb5c10] to-[#ff7d1b] p-6 md:p-10 flex flex-col justify-center">
          <h3 class="text-[42px] md:text-5xl leading-[0.95] font-semibold text-white mb-4 md:mb-5 font-sans">{t("home_installation_title", "Installation services")}</h3>
          <p class="text-white/85 text-xs md:text-sm mb-5 md:mb-7 max-w-md">{t("home_installation_desc", "Dicta sunt explicabo. Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia.")}</p>
          <a href="/get-a-quote" class="inline-flex items-center justify-center w-fit px-5 md:px-7 py-2.5 md:py-3 border border-white text-white text-xs md:text-sm font-semibold hover:bg-white hover:text-[#eb5c10] transition-all">
            {t("home_request_quote_label", "Request a Quote")}
          </a>
        </div>
        <div class="relative overflow-hidden min-h-[200px] md:h-[240px] bg-[#e8edf1] flex items-center">
          <div class="flex-1 p-6 md:p-10 flex flex-col justify-center z-10">
          <h3 class="text-[48px] md:text-[35px] leading-[0.95] md:leading-[1.02] font-semibold text-[#10275c] mb-3 md:mb-4 font-sans">{t("home_comfort_title", "Built for commercial kitchens")}</h3>
          <p class="text-[#6f7e9a] text-xs md:text-sm mb-5 md:mb-7">{t("home_comfort_desc", "Stainless steel products and systems designed for hygiene, durability, and compliance.")}</p>
            <a href="/shop" class="inline-flex items-center justify-center w-fit px-5 md:px-7 py-2.5 md:py-3 bg-[#22a3e6] text-white text-xs md:text-sm font-semibold hover:bg-[#1c90cb] transition-colors">
              {t("home_learn_more_label", "Learn More")}
            </a>
          </div>
          <div class="w-[32%] h-full flex-shrink-0 hidden md:block">
            <img src={t("home_comfort_image", "/images/air-conditioner.jpg")} alt="Our products" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- Brands -->
    <section class="container mx-auto px-4 lg:px-8 py-10 md:py-20">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 items-center">
        {[
          t("home_brand_1", "ELEVATE"),
          t("home_brand_2", "AXION"),
          t("home_brand_3", "SPLENDOR"),
          t("home_brand_4", "DELT")
        ].map((name) => (
          <div class="text-center text-[#bfc7d4] text-[36px] md:text-3xl font-semibold tracking-wide">
            {name}
          </div>
        ))}
        <div class="col-span-2 md:col-span-1 md:justify-self-end">
          <h3 class="text-[56px] md:text-[50px] leading-[0.92] md:leading-[0.98] font-semibold text-[#10275c] font-sans">
            {t("home_brands_title", "We work with the best brands")}
          </h3>
        </div>
      </div>
    </section>

    <!-- Gallery Strip -->
    <section class="grid grid-cols-2 md:grid-cols-6 overflow-hidden">
      {[
        t("home_gallery_1", "/images/welding.jpg"),
        t("home_gallery_2", "/images/air-conditioner.jpg"),
        t("home_gallery_3", "/images/hero-kitchen.jpg"),
        t("home_gallery_4", "/images/installation-service.jpg"),
        t("home_gallery_5", "/images/workshop.jpg"),
        t("home_gallery_6", "/images/mesh-filter.jpg"),
      ].map((img) => (
        <div class="overflow-hidden h-28 md:h-56">
          <img src={img} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover" />
        </div>
      ))}
    </section>
  </div>
</BaseLayout>
