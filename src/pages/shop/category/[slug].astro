---
export const prerender = false;
/**
 * shop/category/[slug].astro — Category page (PURE ASTRO, SSR)
 *
 * Server-rendered: fetches fresh category + products data on every request.
 * This ensures new products appear immediately after being added in admin.
 */
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getStandardizedDisplayPrice, getStandardizedDisplayTitle } from '@/lib/pricing';
import { buildBreadcrumbJsonLd, buildItemListJsonLd } from '@/lib/seo';

const siteUrl = import.meta.env.SITE;
const API = 'http://127.0.0.1:8000/api/v1';
const { slug } = Astro.params;

// Fetch category info + products in parallel at request time
let category: any = null;
let products: any[] = [];

try {
  const [catRes, prodRes] = await Promise.all([
    fetch(`${API}/product-categories`).then(r => r.ok ? r.json() : []),
    fetch(`${API}/products?category=${slug}`).then(r => r.ok ? r.json() : { data: [] }),
  ]);
  
  const allCategories = Array.isArray(catRes) ? catRes : catRes.data || [];
  category = allCategories.find((c: any) => c.slug === slug) || null;
  products = prodRes.data || [];
} catch (e) {
  console.error('Failed to fetch category data:', e);
}

// 404 if category not found
if (!category) {
  return Astro.redirect('/404');
}

const pageTitle = category?.name || 'Category';
const pageDescription = category?.description || `Browse ${pageTitle} products from Midia M Metal.`;

// Cache headers: CDN caches for 5 min
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=3600');

// CollectionPage + ItemList JSON-LD
const categoryUrl = `${siteUrl}/shop/category/${slug}`;
const itemListJsonLd = products.length > 0
  ? buildItemListJsonLd({
      name: pageTitle,
      description: pageDescription,
      url: categoryUrl,
      items: products.map((p: any) => ({
        url: `${siteUrl}/shop/${p.slug || p.id}`,
        name: p.name,
      })),
    })
  : null;

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Shop', url: `${siteUrl}/shop` },
  { name: pageTitle, url: categoryUrl },
]);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={category?.image}
  canonicalPath={`/shop/category/${slug}`}
  structuredData={[breadcrumbJsonLd, ...(itemListJsonLd ? [itemListJsonLd] : [])]}
>
  <div class="min-h-screen bg-[#eaf0f3]">
    <!-- Hero section with category overview -->
    <section class="container mx-auto px-4 lg:px-8 pt-16 md:pt-20 pb-16 md:pb-20">
      <!-- Breadcrumb -->
      <div class="mb-6">
        <nav class="flex items-center gap-2 text-sm text-[#6e7a92]">
          <a href="/shop" class="hover:text-orange transition-colors">Shop</a>
          <span>/</span>
          <span class="text-primary">{category.name}</span>
        </nav>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[45%_55%] gap-8 md:gap-10 items-center">
        <div class="bg-[#f4f5f7]">
          <Image
            src={category.image}
            alt={category.name}
            width={1200}
            height={400}
            loading="eager"
            decoding="async"
            class="w-full h-[280px] md:h-[420px] object-cover"
          />
        </div>
        <div>
          <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-[#10275c] mb-4">Category Overview</p>
          <h1 class="font-sans text-[34px] md:text-[48px] leading-[0.96] font-semibold text-[#10275c] mb-5">
            {category.name}
          </h1>
          <p class="text-[15px] leading-8 text-[#6f7c95]">{category.description}</p>
        </div>
      </div>
    </section>

    <!-- Products grid -->
    <section class="container mx-auto px-4 lg:px-8 pb-20 md:pb-24">
      <h3 class="font-sans text-[34px] md:text-[46px] leading-none font-semibold text-[#10275c] mb-8">Products</h3>

      {products.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 md:gap-x-8 gap-y-10">
          {products.map((product: any) => (
            <a href={`/shop/${product.slug || product.id}`} class="group">
              <div class="bg-[#f7f8fa] mb-4">
                <Image
                  src={product.image}
                  alt={product.name}
                  width={400}
                  height={400}
                  loading="lazy"
                  decoding="async"
                  class="w-full aspect-square object-contain transition-transform duration-300 group-hover:scale-[1.02]"
                />
              </div>
              <h4 class="font-sans text-[18px] md:text-[20px] leading-tight font-semibold text-primary group-hover:text-orange transition-colors">
                {getStandardizedDisplayTitle(product)}
              </h4>
              <p class="text-[16px] md:text-[20px] text-[#5e6e8c] mt-2">
                {getStandardizedDisplayPrice(product)}
              </p>
            </a>
          ))}
        </div>
      ) : (
        <div class="py-12 px-6 border border-[#cfd8e6] bg-[#f4f5f7] text-[#6f7c95]">
          No products found for this category.
        </div>
      )}
    </section>
  </div>
</BaseLayout>
