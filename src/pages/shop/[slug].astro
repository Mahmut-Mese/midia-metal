---
export const prerender = false;
/**
 * shop/[slug].astro — Product detail page (SSR)
 *
 * Server-rendered: fetches fresh product + related data on every request.
 * This ensures prices, stock, and reviews are always current.
 *
 * SEO: Product JSON-LD for rich snippets + breadcrumbs.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductDetailIsland from '@/islands/ProductDetailIsland';
import { getStandardizedDisplayPrice, parseMoneyValue } from '@/lib/pricing';
import { stripHtml, truncateText, buildBreadcrumbJsonLd, buildProductJsonLd } from '@/lib/seo';

const siteUrl = import.meta.env.SITE;
const API = `${(import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000/api').replace(/\/+$/, '')}/v1`;
const { slug } = Astro.params;

// Cache headers: CDN caches for 5 min, serves stale while revalidating for 1 hour
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=3600');

// Fetch product detail + related products in parallel at request time
let product: any = null;
let related: any[] = [];

try {
  const [productRes, relatedRes] = await Promise.all([
    fetch(`${API}/products/${slug}`).then(r => r.ok ? r.json() : null),
    fetch(`${API}/products/${slug}/related`).then(r => r.ok ? r.json() : []),
  ]);
  product = productRes;
  related = (Array.isArray(relatedRes) ? relatedRes : []).slice(0, 3);
} catch (e) {
  console.error('Failed to fetch product data:', e);
}

// 404 if product not found
if (!product) {
  return Astro.redirect('/404');
}

// Dynamic SEO from product data
const productName = product?.name || 'Product';
const productPrice = product ? getStandardizedDisplayPrice(product) : '';
const pageTitle = productPrice ? `${productName} - ${productPrice}` : productName;
const rawDescription = product?.description || '';
const pageDescription = rawDescription
  ? truncateText(stripHtml(rawDescription), 155)
  : `View ${productName} details from Midia M Metal.`;

// Product JSON-LD for rich snippets in Google Search
const productUrl = `${siteUrl}/shop/${slug}`;
const numericPrice = parseMoneyValue(productPrice.replace('£', '')) ?? 0;
const productJsonLd = buildProductJsonLd({
  name: productName,
  description: rawDescription,
  image: product?.image,
  sku: product?.sku || String(product?.id || ''),
  url: productUrl,
  price: numericPrice,
  availability: product?.stock > 0 || product?.in_stock !== false
    ? 'https://schema.org/InStock'
    : 'https://schema.org/OutOfStock',
  ratingValue: product?.average_rating,
  reviewCount: product?.review_count,
});

const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Shop', url: `${siteUrl}/shop` },
  ...(product?.category ? [{ name: product.category.name || product.category, url: `${siteUrl}/shop/category/${product.category.slug || ''}` }] : []),
  { name: productName, url: productUrl },
]);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={product?.image}
  canonicalPath={`/shop/${slug}`}
  structuredData={[productJsonLd, breadcrumbJsonLd]}
>
  <div class="min-h-screen bg-[#eaf0f3]">
    <ProductDetailIsland
      id={slug!}
      initialProduct={product}
      initialRelated={related}
      client:load
    />
  </div>
</BaseLayout>
