---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Order Confirmation"
  description="Your order confirmation page."
  canonicalPath="/thank-you"
  noindex
>
  <div class="min-h-screen bg-[#eaf0f3]">
    <!-- Checkout Steps (step 4 = Complete is active, steps 1-3 are done) -->
    <section class="container mx-auto px-4 lg:px-8 pt-16 md:pt-24 pb-4 md:pb-6">
      <div class="mx-auto mb-8 max-w-5xl px-2 md:mb-14 md:px-4">
        <ol class="grid grid-cols-2 gap-x-4 gap-y-6 md:grid-cols-4 md:gap-x-6 md:gap-y-0">
          <!-- Step 1: Cart (done) -->
          <li class="relative">
            <div>
              <span class="grid h-12 w-12 place-items-center rounded-full border border-primary bg-primary text-white text-base font-semibold transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="mt-3 block text-[13px] leading-tight md:text-sm font-semibold text-[#4f5d79]">Cart</span>
            </div>
            <span class="absolute left-14 top-6 hidden h-[2px] w-[calc(100%-3.5rem)] md:block bg-primary" aria-hidden="true"></span>
          </li>
          <!-- Step 2: Deliver / Collect (done) -->
          <li class="relative">
            <div>
              <span class="grid h-12 w-12 place-items-center rounded-full border border-primary bg-primary text-white text-base font-semibold transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="mt-3 block text-[13px] leading-tight md:text-sm font-semibold text-[#4f5d79]">Deliver / Collect</span>
            </div>
            <span class="absolute left-14 top-6 hidden h-[2px] w-[calc(100%-3.5rem)] md:block bg-primary" aria-hidden="true"></span>
          </li>
          <!-- Step 3: Checkout (done) -->
          <li class="relative">
            <div>
              <span class="grid h-12 w-12 place-items-center rounded-full border border-primary bg-primary text-white text-base font-semibold transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="mt-3 block text-[13px] leading-tight md:text-sm font-semibold text-[#4f5d79]">Checkout</span>
            </div>
            <span class="absolute left-14 top-6 hidden h-[2px] w-[calc(100%-3.5rem)] md:block bg-primary" aria-hidden="true"></span>
          </li>
          <!-- Step 4: Complete (current) -->
          <li class="relative">
            <div>
              <span class="grid h-12 w-12 place-items-center rounded-full border border-primary bg-primary text-white text-base font-semibold transition-colors">4</span>
              <span class="mt-3 block text-[13px] leading-tight md:text-sm font-bold text-primary">Complete</span>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- Order Confirmation Card -->
    <section class="container mx-auto px-4 lg:px-8 pb-20 md:pb-28 max-w-[920px]">
      <div class="flex justify-center mb-6">
        <div class="w-20 h-20 border border-[#cad4e4] bg-[#f4f5f7] grid place-items-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 text-orange"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
      </div>
      <h2 class="text-center font-sans text-[40px] md:text-[56px] leading-none font-semibold text-primary mb-4">Thank You</h2>
      <p class="text-center text-[15px] text-[#6f7c95] leading-8 mb-10 max-w-[700px] mx-auto">
        Your order has been placed successfully. We'll send you a confirmation email with your order details shortly.
      </p>

      <div class="border border-[#cad4e4] overflow-hidden text-left mb-10">
        <div class="grid grid-cols-[42%_58%] border-b border-[#cad4e4]">
          <span class="font-semibold text-sm md:text-lg text-primary bg-[#f4f5f7] p-4 md:p-6">Order Number</span>
          <span id="order-number" class="text-sm md:text-base text-primary p-4 md:p-6"></span>
        </div>
        <div class="grid grid-cols-[42%_58%] border-b border-[#cad4e4]">
          <span class="font-semibold text-sm md:text-lg text-primary bg-[#f4f5f7] p-4 md:p-6">Date</span>
          <span id="order-date" class="text-sm md:text-base text-primary p-4 md:p-6"></span>
        </div>
        <div class="grid grid-cols-[42%_58%] border-b border-[#cad4e4]">
          <span class="font-semibold text-sm md:text-lg text-primary bg-[#f4f5f7] p-4 md:p-6">Payment Method</span>
          <span id="payment-method" class="text-sm md:text-base text-primary p-4 md:p-6"></span>
        </div>
        <div class="grid grid-cols-[42%_58%] border-b border-[#cad4e4]">
          <span class="font-semibold text-sm md:text-lg text-primary bg-[#f4f5f7] p-4 md:p-6">Product</span>
          <div id="order-items" class="text-sm md:text-base text-primary p-4 md:p-6 flex flex-col gap-1">
            <span>Order Processing</span>
          </div>
        </div>
        <div class="grid grid-cols-[42%_58%]">
          <span class="font-semibold text-sm md:text-lg text-primary bg-[#f4f5f7] p-4 md:p-6">Total</span>
          <span id="order-total" class="font-semibold text-base md:text-2xl text-primary p-4 md:p-6"></span>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-8 h-14 bg-orange text-white text-sm font-semibold hover:bg-orange-hover transition-colors"
        >
          Back to Home
        </a>
        <a
          href="/shop"
          class="inline-flex items-center justify-center px-8 h-14 bg-white text-primary text-sm font-semibold border border-[#cad4e4] hover:bg-[#f6f8fb] transition-colors"
        >
          Continue Shopping
        </a>
      </div>
    </section>
  </div>

  <script>
    const stored = sessionStorage.getItem('lastOrder');
    if (stored) {
      try {
        const data = JSON.parse(stored);
        sessionStorage.removeItem('lastOrder');

        const orderNumberEl = document.getElementById('order-number');
        if (orderNumberEl) {
          orderNumberEl.textContent = data.orderNumber || '#' + Math.floor(10000 + Math.random() * 90000);
        }

        const orderDateEl = document.getElementById('order-date');
        if (orderDateEl) {
          orderDateEl.textContent = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
        }

        const paymentMethodEl = document.getElementById('payment-method');
        if (paymentMethodEl) {
          paymentMethodEl.textContent = data.method || 'Credit / Debit Card';
        }

        const orderTotalEl = document.getElementById('order-total');
        if (orderTotalEl) {
          orderTotalEl.textContent = data.total || '£0.00';
        }

        const itemsEl = document.getElementById('order-items');
        if (itemsEl && data.items && data.items.length > 0) {
          itemsEl.innerHTML = data.items.map(function(item) {
            return '<span>' + item.name + ' x ' + item.qty + '</span>';
          }).join('');
        }
      } catch (e) {
        // Silently handle parse errors
      }
    }
  </script>
</BaseLayout>
