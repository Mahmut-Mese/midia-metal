---
/**
 * blog/index.astro — Blog list page (PURE ASTRO)
 *
 * Original: src/pages-react/BlogPage.tsx
 * React island: src/islands/BlogIsland.tsx (147 lines, 4 API calls)
 * Converted: Pure Astro with data fetched at build time.
 *
 * Pattern:
 *   1. Fetch ALL data in frontmatter using direct fetch() to backend
 *   2. Transform settings array → key-value map
 *   3. Render as pure HTML/Astro template — NO React, NO useState, NO useEffect
 *   4. Use inline SVGs instead of lucide-react icons
 *   5. Use `class` instead of `className`
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd, buildItemListJsonLd } from '@/lib/seo';
import { fetchSettings, getPageTitle, getPageDescription } from '@/lib/settings';

const siteUrl = import.meta.env.SITE;
const API_BASE = 'http://127.0.0.1:8000/api';

// --- Data Fetching (runs at build time) ---
const settings = await fetchSettings();

let posts: any[] = [];
let categories: any[] = [];
let recentPosts: any[] = [];

try {
  const [postsRes, catRes, recentRes] = await Promise.all([
    fetch(`${API_BASE}/v1/blog`).then(r => r.ok ? r.json() : { data: [] }),
    fetch(`${API_BASE}/v1/blog/categories`).then(r => r.ok ? r.json() : []),
    fetch(`${API_BASE}/v1/blog/recent`).then(r => r.ok ? r.json() : []),
  ]);
  posts = postsRes.data || postsRes || [];
  categories = catRes || [];
  recentPosts = recentRes || [];
} catch (err) {
  console.error('Failed to load blog data at build time:', err);
}

const t = (key: string, def: string) => settings[key] || def;

// ItemList JSON-LD for blog listing
const blogUrl = `${siteUrl}/blog`;
const itemListJsonLd = posts.length > 0
  ? buildItemListJsonLd({
      name: 'Blog',
      description: 'Articles and insights from Midia M Metal.',
      url: blogUrl,
      items: posts.map((p: any) => ({
        url: `${siteUrl}/blog/${p.slug}`,
        name: p.title,
      })),
    })
  : null;
---

<BaseLayout
  title={getPageTitle(settings, 'blog_hero_title', 'Blog')}
  description={getPageDescription(settings, undefined, 'Read insights on commercial kitchen ventilation, stainless steel fabrication, canopy systems, hygiene, and maintenance from Midia M Metal.')}
  canonicalPath="/blog"
  structuredData={[
    buildBreadcrumbJsonLd([
      { name: 'Home', url: `${siteUrl}/` },
      { name: 'Blog', url: blogUrl },
    ]),
    ...(itemListJsonLd ? [itemListJsonLd] : []),
  ]}
>
  <div class="min-h-screen bg-[#eaf0f3]">
    <section class="container mx-auto px-4 lg:px-8 pt-16 md:pt-20 pb-20 md:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_340px] xl:grid-cols-[minmax(0,1fr)_370px] gap-8 lg:gap-10">
        <!-- Main Content -->
        <div>
          <p class="text-[13px] text-[#9aa6bc] mb-8">Showing results for blog</p>
          {posts.length > 0 ? (
            <div class="space-y-10">
              {posts.map((post) => (
                <article class="group">
                  <a href={`/blog/${post.slug}`} class="block relative overflow-hidden bg-[#f7f8fa]">
                    <img
                      src={post.image}
                      alt={post.title}
                      loading="lazy" decoding="async"
                      class="w-full h-[260px] md:h-[360px] object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                    />
                    {post.category && (
                      <span class="absolute top-4 left-4 h-8 px-3 inline-flex items-center bg-orange text-white text-[11px] font-semibold uppercase tracking-wide">
                        {post.category}
                      </span>
                    )}
                  </a>
                  <div class="pt-5">
                    <div class="flex items-center gap-5 text-[13px] text-[#6f7c95] mb-3">
                      <span class="flex items-center gap-1">
                        <!-- Calendar icon -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#2f9cea]"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                        {new Date(post.published_at || post.created_at).toLocaleDateString()}
                      </span>
                      <span class="flex items-center gap-1">
                        <!-- User icon -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#2f9cea]"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        {post.author}
                      </span>
                    </div>
                    <a href={`/blog/${post.slug}`}>
                      <h2 class="font-sans text-[32px] md:text-[42px] leading-[0.96] font-semibold text-orange hover:text-orange/80 transition-colors mb-4">
                        {post.title}
                      </h2>
                    </a>
                    <p class="text-[15px] leading-8 text-[#6f7c95] mb-5">{post.excerpt}</p>
                    <a
                      href={`/blog/${post.slug}`}
                      class="inline-flex items-center gap-2 text-[13px] font-semibold text-[#10275c] hover:text-orange transition-colors"
                    >
                      Read More
                      <!-- ArrowRight icon -->
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="py-16 text-center text-[#6e7a92] bg-[#f4f5f7] border border-[#d5deea]">No blog posts found.</div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="bg-[#f4f5f7] p-6 md:p-8 h-fit lg:sticky lg:top-28 space-y-8">
          <div>
            <h3 class="font-sans text-[16px] leading-none font-semibold text-primary mb-5">{t("blog_sidebar_search", "Search")}</h3>
            <div class="relative">
              <!-- Search icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-[#8a95ac]"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              <input
                type="text"
                placeholder="Search for article..."
                class="w-full h-12 border border-[#d1dbe8] bg-transparent pl-12 pr-4 text-[14px] text-primary placeholder:text-[#9aa6bc] outline-none"
              />
            </div>
          </div>

          <div>
            <h3 class="font-sans text-[16px] leading-none font-semibold text-primary mb-5">{t("blog_sidebar_categories", "Categories")}</h3>
            <ul class="space-y-2">
              {categories.map((category) => (
                <li>
                  <span class="text-[15px] inline-flex items-center gap-2 text-primary hover:text-orange transition-colors cursor-pointer">
                    <span class="text-[8px]">•</span>
                    {category.category} ({category.count})
                  </span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="font-sans text-[16px] leading-none font-semibold text-primary mb-5">{t("blog_sidebar_recent", "Recent Posts")}</h3>
            <ul class="space-y-4">
              {recentPosts.map((post) => (
                <li class="flex gap-3">
                  <img src={post.image} alt={post.title} loading="lazy" decoding="async" class="w-20 h-20 object-cover flex-shrink-0 bg-[#f7f8fa]" />
                  <div>
                    <a href={`/blog/${post.slug}`} class="text-[15px] font-semibold text-orange hover:text-orange/80 transition-colors leading-snug">
                      {post.title}
                    </a>
                    <p class="text-[12px] text-[#7f8aa2] mt-2">
                      {new Date(post.published_at || post.created_at).toLocaleDateString()}
                    </p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </section>
  </div>
</BaseLayout>
