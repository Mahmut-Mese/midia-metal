---
/**
 * 404.astro — Reference conversion: STATIC PAGE (no API, no interactivity)
 *
 * Pattern: Pure Astro markup. No React islands needed.
 * Original: src/pages-react/NotFound.tsx
 *
 * This is the simplest conversion type — static HTML wrapped in BaseLayout.
 * The bulk-converter agent should follow this exact pattern for similar pages.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 Not Found"
  description="The page you requested could not be found."
  noindex
>
  <div class="flex min-h-[60vh] items-center justify-center bg-muted">
    <div class="text-center">
      <h1 class="mb-4 text-4xl font-bold">404</h1>
      <p class="mb-4 text-xl text-muted-foreground">Oops! Page not found</p>
      <a href="/" class="text-primary underline hover:text-primary/90">
        Return to Home
      </a>
    </div>
  </div>
</BaseLayout>
