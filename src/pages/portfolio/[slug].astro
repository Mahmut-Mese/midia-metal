---
/**
 * portfolio/[slug].astro — Portfolio detail page (PURE ASTRO)
 *
 * Converted from React island: src/islands/PortfolioDetailIsland.tsx
 * All data fetched at build time via getStaticPaths.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd } from '@/lib/seo';

const siteUrl = import.meta.env.SITE;

export async function getStaticPaths() {
  try {
    const allProjects = await fetch('http://127.0.0.1:8000/api/v1/portfolio').then(r => r.ok ? r.json() : []);
    
    return await Promise.all((allProjects || []).map(async (project: any) => {
      // Fetch full project detail
      const detail = await fetch(`http://127.0.0.1:8000/api/v1/portfolio/${project.slug}`).then(r => r.ok ? r.json() : project);
      
      // Fetch related projects from same category
      const categorySlug = detail.portfolio_category?.slug;
      let related: any[] = [];
      if (categorySlug) {
        const relRes = await fetch(`http://127.0.0.1:8000/api/v1/portfolio?category=${categorySlug}`).then(r => r.ok ? r.json() : []);
        related = (relRes || []).filter((p: any) => p.slug !== project.slug).slice(0, 3);
      }
      
      return {
        params: { slug: project.slug },
        props: { project: detail, related },
      };
    }));
  } catch (e) {
    console.warn('Could not fetch portfolio projects for static paths');
    return [];
  }
}

const { slug } = Astro.params;
const { project, related } = Astro.props;
---

<BaseLayout
  title={project?.title || 'Project'}
  description={`${project?.title || 'Project'} - A portfolio project by Midia M Metal showcasing our commercial kitchen and fabrication work.`}
  canonicalPath={`/portfolio/${slug}`}
  structuredData={[buildBreadcrumbJsonLd([
    { name: 'Home', url: `${siteUrl}/` },
    { name: 'Portfolio', url: `${siteUrl}/portfolio` },
    { name: project?.title || 'Project', url: `${siteUrl}/portfolio/${slug}` },
  ])]}
>
  <div class="min-h-screen bg-[#eaf0f3]">
    {project ? (
      <>
        <section class="container mx-auto px-4 lg:px-8 pt-16 md:pt-24 pb-14 md:pb-20">
          <div class="grid grid-cols-1 xl:grid-cols-[68%_32%] gap-8 xl:gap-10 items-start">
            <div>
              <img src={project.image} alt={project.title} loading="lazy" decoding="async" class="w-full h-[360px] md:h-[520px] object-cover" />

              <p class="mt-8 text-[10px] font-bold uppercase tracking-[0.22em] text-muted-foreground">{project.portfolio_category?.name || "Uncategorized"}</p>
              <h2 class="font-sans text-[42px] md:text-[58px] leading-[0.95] font-semibold text-[#10275c] mt-3 mb-6">{project.title}</h2>

              <p class="text-[15px] text-[#6f7c95] leading-8 mb-6 whitespace-pre-wrap">
                {project.description || "No description provided."}
              </p>

              {project.gallery && project.gallery.length > 0 && (
                <div class={`grid grid-cols-1 ${project.gallery.length >= 2 ? 'md:grid-cols-2' : ''} gap-4 mb-8`}>
                  {project.gallery.map((imgUrl: string) => (
                    <img src={imgUrl} alt="" loading="lazy" decoding="async" class="w-full h-[280px] object-cover" />
                  ))}
                </div>
              )}
            </div>

            <aside class="bg-[#f4f5f7] p-8">
              <h3 class="font-sans text-[30px] leading-none font-semibold text-primary mb-8">Project Info</h3>
              <div class="space-y-5 text-[15px] text-[#6f7c95]">
                <div class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#2f9cea] mt-1"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  <p>
                    <span class="text-primary font-semibold">Client:</span> {project.client || "N/A"}
                  </p>
                </div>
                <div class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#2f9cea] mt-1"><line x1="4" x2="20" y1="9" y2="9"/><line x1="4" x2="20" y1="15" y2="15"/><line x1="10" x2="8" y1="3" y2="21"/><line x1="16" x2="14" y1="3" y2="21"/></svg>
                  <p>
                    <span class="text-primary font-semibold">Customer Number:</span> {project.customer_number || "N/A"}
                  </p>
                </div>
                <div class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#2f9cea] mt-1"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  <p>
                    <span class="text-primary font-semibold">Location:</span> {project.location || "N/A"}
                  </p>
                </div>
                <div class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#2f9cea] mt-1"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                  <p>
                    <span class="text-primary font-semibold">Year:</span> {project.year || "N/A"}
                  </p>
                </div>
              </div>

              {project.services_list && project.services_list.length > 0 && (
                <>
                  <h4 class="font-sans text-[24px] leading-none font-semibold text-primary mt-10 mb-4">Services</h4>
                  <ul class="space-y-2">
                    {project.services_list.map((service: string) => (
                      <li class="text-[14px] text-[#6f7c95]">
                        - {service}
                      </li>
                    ))}
                  </ul>
                </>
              )}

              <a
                href="/contact"
                class="mt-10 inline-flex items-center justify-center h-12 px-8 w-full bg-orange text-white text-[14px] font-semibold hover:bg-[#d4500b] transition-colors"
              >
                Start Your Project
              </a>
            </aside>
          </div>
        </section>

        {related.length > 0 && (
          <section class="container mx-auto px-4 lg:px-8 pb-24">
            <h3 class="font-sans text-[38px] md:text-[50px] leading-none font-semibold text-[#10275c] mb-8">Related Projects</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {related.map((item: any) => (
                <a href={`/portfolio/${item.slug}`} class="group">
                  <div class="mb-4 overflow-hidden">
                    <img src={item.image} alt={item.title} loading="lazy" decoding="async" class="w-full h-[240px] object-cover transition-transform duration-300 group-hover:scale-105" />
                  </div>
                  <h4 class="font-sans text-[20px] font-semibold text-orange">{item.title}</h4>
                  <p class="text-[14px] text-[#6f7c95] mt-1">{item.portfolio_category?.name || "Uncategorized"}</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <section class="container mx-auto px-4 lg:px-8 py-20 text-center">
        <h1 class="font-sans text-[44px] font-semibold text-[#10275c] mb-4">Project Not Found</h1>
        <a href="/portfolio" class="text-orange underline">
          Back to portfolio
        </a>
      </section>
    )}
  </div>
</BaseLayout>
