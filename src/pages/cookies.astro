---
/**
 * cookies.astro — Cookies Policy page (PURE ASTRO)
 *
 * Converted from React island (LegalIsland.tsx) to pure Astro.
 * All data fetching happens at build time via frontmatter.
 * Zero client-side JavaScript for page content.
 *
 * Original: src/islands/LegalIsland.tsx
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd } from '@/lib/seo';

const siteUrl = import.meta.env.SITE;
const API_BASE = 'http://127.0.0.1:8000/api';

// --- Data Fetching (runs at build time) ---
let settings: Record<string, string> = {};

try {
  const settingsRes = await fetch(`${API_BASE}/v1/settings`).then(r => r.ok ? r.json() : []);
  const settingsMap: Record<string, string> = {};
  (settingsRes || []).forEach((s: any) => {
    settingsMap[s.key] = s.value;
  });
  settings = settingsMap;
} catch (err) {
  console.error('Failed to load cookies policy data at build time:', err);
}

const title = settings['cookies_page_title'] || 'Cookies Page';
const fallbackContent = `<h2>1. What Are Cookies?</h2>
<p>Cookies are small text files placed on your computer or mobile device by websites that you visit.</p>
<h2>2. How We Use Cookies</h2>
<p>We use cookies for several reasons:</p>
<ul>
  <li><strong>Essential Cookies:</strong> Required for the operation of our website, including shopping cart functionality.</li>
  <li><strong>Performance Cookies:</strong> Help us understand how visitors use the site so we can improve it.</li>
  <li><strong>Functionality Cookies:</strong> Remember your preferences and improve your browsing experience.</li>
</ul>
<h2>3. Managing Cookies</h2>
<p>Most browsers allow control of cookies through browser settings. You can also review and change your cookie preferences on our site where available.</p>
<h2>4. Consent</h2>
<p>By using our website, you consent to our use of cookies as described in this policy.</p>
<h2>5. Contact Us</h2>
<p>If you have questions about our use of cookies, contact <a href="mailto:info@midiametal.co.uk">info@midiametal.co.uk</a>.</p>`;
const content = settings['cookies_page_content'] || fallbackContent;
---

<BaseLayout
  title="Cookies Policy"
  description="Learn about how Midia M Metal uses cookies on our website."
  canonicalPath="/cookies"
  structuredData={[
    buildBreadcrumbJsonLd([
      { name: 'Home', url: `${siteUrl}/` },
      { name: 'Cookies Policy', url: `${siteUrl}/cookies` },
    ]),
  ]}
>
  <div class="min-h-screen bg-[#eaf0f3]">
    <section class="container mx-auto px-4 lg:px-8 pt-16 md:pt-24 pb-20 md:pb-28 max-w-3xl">
      <div class="bg-white border border-[#cad4e4] p-8 md:p-12 prose prose-slate max-w-none prose-headings:text-[#10275c] prose-a:text-orange prose-a:no-underline hover:prose-a:underline">
        <h1 class="font-sans text-[32px] md:text-[42px] leading-tight font-semibold text-orange mb-8">
          {title}
        </h1>
        <div set:html={content} />
      </div>
    </section>
  </div>
</BaseLayout>
