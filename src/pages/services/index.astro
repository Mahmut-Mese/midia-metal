---
/**
 * services/index.astro — Services list page (PURE ASTRO)
 *
 * REFERENCE CONVERSION: This is the template pattern for converting React islands
 * to pure Astro pages. All static-content pages should follow this approach.
 *
 * Pattern:
 *   1. Fetch ALL data in frontmatter using direct fetch() to backend
 *   2. Transform data (settings array → key-value map)
 *   3. Render as pure HTML/Astro template — NO React, NO useState, NO useEffect
 *   4. Use inline SVGs instead of lucide-react icons
 *   5. Use `class` instead of `className`
 *   6. Use Astro's native {expression} syntax for dynamic content
 *   7. No loading states needed — data is available at build time
 *
 * Original React island: src/islands/ServicesIsland.tsx (215 lines, 3 API calls)
 * Converted: Pure Astro (0 client-side JS for this page content)
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd } from '@/lib/seo';

const siteUrl = import.meta.env.SITE;
const API_BASE = 'http://127.0.0.1:8000/api';

// --- Data Fetching (runs at build time) ---
let services: any[] = [];
let testimonials: any[] = [];
let settings: Record<string, string> = {};

try {
  const [servicesRes, settingsRes, testimonialsRes] = await Promise.all([
    fetch(`${API_BASE}/v1/services`).then(r => r.ok ? r.json() : []),
    fetch(`${API_BASE}/v1/settings`).then(r => r.ok ? r.json() : []),
    fetch(`${API_BASE}/v1/testimonials`).then(r => r.ok ? r.json() : []),
  ]);
  services = servicesRes || [];
  testimonials = testimonialsRes || [];
  // Transform settings array to key-value map
  const settingsMap: Record<string, string> = {};
  (settingsRes || []).forEach((s: any) => {
    settingsMap[s.key] = s.value;
  });
  settings = settingsMap;
} catch (err) {
  console.error('Failed to load services data at build time:', err);
}

// Helper: get setting
const t = (key: string) => settings[key] || '';
---

<BaseLayout
  title="Services"
  description="Commercial kitchen ventilation, stainless steel welding, custom fabrication, canopy installation, and maintenance services across the UK."
  canonicalPath="/services"
  structuredData={[
    buildBreadcrumbJsonLd([
      { name: 'Home', url: `${siteUrl}/` },
      { name: 'Services', url: `${siteUrl}/services` },
    ]),
  ]}
>
  <div class="min-h-screen bg-[#eaf0f3]">
    <!-- Hero Section -->
    <section class="container mx-auto px-4 lg:px-8 pt-16 md:pt-20 pb-16 md:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="max-w-xl">
          <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-[#10275c] mb-4">{t("services_hero_label")}</p>
          <h2 class="font-sans text-[48px] md:text-[62px] leading-[0.95] font-semibold text-[#10275c] mb-6">{t("services_hero_subtitle")}</h2>
          <p class="text-[#1c2b4a] text-[23px] md:text-[26px] leading-[1.25] mb-5">
            {t("services_hero_tagline")}
          </p>
          <p class="text-[#79849d] text-sm leading-7 mb-8 max-w-lg">
            {t("services_hero_desc")}
          </p>
          <div class="flex items-center gap-4 flex-wrap">
            <a href="/about" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white text-sm font-semibold hover:bg-[#d4500b] transition-colors">
              About Us
            </a>
            <a href={`tel:${t("services_hero_phone")}`} class="flex items-center gap-3 text-sm font-semibold text-primary">
              <span class="w-11 h-11 border border-[#d3dbe7] grid place-items-center bg-white">
                <!-- Phone icon (inline SVG replaces lucide-react Phone) -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </span>
              {t("services_hero_phone")}
            </a>
          </div>
        </div>
        <div class="relative h-[360px] md:h-[520px]">
          <div class="absolute right-0 top-0 w-[58%] h-[74%] overflow-hidden">
            <img src={t("services_hero_image_1")} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="absolute left-0 bottom-0 w-[68%] h-[84%] overflow-hidden">
            <img src={t("services_hero_image_2")} alt="Stainless steel welding" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="container mx-auto px-4 lg:px-8 py-16 md:py-24">
      <p class="text-center text-[10px] font-bold tracking-[0.24em] text-muted-foreground uppercase mb-3">{t("services_quality_label")}</p>
      <h2 class="text-center font-sans text-[44px] md:text-[62px] leading-[0.95] font-semibold text-[#10275c] mb-12 md:mb-16 whitespace-pre-line">
        {t("services_quality_title")}
      </h2>
      {services.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-14">
          {services.map((s: any) => (
            <div class="text-center">
              <a href={`/services/${s.slug}`} class="block">
                <div class="w-44 h-44 mx-auto rounded-full overflow-hidden mb-7 border-8 border-[#eaf0f3] shadow-sm">
                  <img src={s.image} alt={s.title} loading="lazy" decoding="async" class="w-full h-full object-cover" />
                </div>
              </a>
              <p class="text-xs text-muted-foreground mb-1">Best service</p>
              <h3 class="font-sans text-[33px] leading-tight font-semibold text-[#10275c] mb-3">
                <a href={`/services/${s.slug}`} class="hover:text-orange transition-colors">
                  {s.title}
                </a>
              </h3>
              <p class="text-sm text-[#7b879f] leading-relaxed mb-5 max-w-sm mx-auto">{s.description}</p>
              <a href={`/services/${s.slug}`} class="inline-flex items-center justify-center w-8 h-8 rounded-full border border-[#cfd8e6] text-primary hover:text-orange hover:border-orange transition-colors">
                <!-- ArrowRight icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              </a>
            </div>
          ))}
        </div>
      ) : (
        <div class="py-16 text-center text-[#6e7a92] bg-[#f4f5f7] border border-[#d5deea]">No services available.</div>
      )}
    </section>

    <!-- CTA Banner -->
    <section class="bg-gradient-to-r from-[#0c63a4] to-[#1296df]">
      <div class="container mx-auto px-4 lg:px-8 py-8 md:py-10 flex flex-col md:flex-row items-center justify-between gap-6">
        <h3 class="font-sans text-[36px] md:text-[44px] leading-[1.05] font-semibold text-white whitespace-pre-line">
          {t("services_cta_title")}
        </h3>
        <div class="flex gap-4 flex-wrap">
          <a href="/get-a-quote" class="inline-flex items-center justify-center px-7 py-3 text-sm font-semibold bg-white text-[#10275c] hover:bg-[#eef3f8] transition-colors duration-200">
            Request a Quote
          </a>
          <a href="/contact" class="inline-flex items-center justify-center px-7 py-3 border border-white text-white text-sm font-semibold hover:bg-white hover:text-[#0f6fb5] transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </section>

    <!-- Modern Solutions -->
    <section class="container mx-auto px-4 lg:px-8 py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div class="flex gap-4">
          <img src={t("services_modern_image_1")} alt="" loading="lazy" decoding="async" class="w-1/2 h-56 md:h-72 object-cover" />
          <img src={t("services_modern_image_2")} alt="" loading="lazy" decoding="async" class="w-1/2 h-56 md:h-72 object-cover" />
        </div>
        <div class="max-w-xl">
          <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-muted-foreground mb-3">{t("services_modern_label")}</p>
          <h2 class="font-sans text-[50px] md:text-[70px] leading-[0.93] font-semibold text-[#10275c] mb-5">{t("services_modern_title")}</h2>
          <p class="text-[#7b879f] text-sm leading-relaxed mb-7">
            {t("services_modern_desc")}
          </p>
          <a href="/shop" class="inline-flex items-center justify-center px-8 py-4 bg-orange text-white text-sm font-semibold hover:bg-[#d4500b] transition-colors">
            Visit Our Online Store
          </a>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="container mx-auto px-4 lg:px-8 py-8 md:py-14">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 text-center">
        <!-- Feature 1: Hammer icon -->
        <div>
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange"><path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"></path><path d="M17.64 15 22 10.64"></path><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"></path></svg>
          </div>
          <h3 class="font-sans text-[34px] leading-tight font-semibold text-primary mb-3">{t("services_feature_1_title")}</h3>
          <p class="text-sm text-muted-foreground max-w-sm mx-auto">{t("services_feature_1_desc")}</p>
          <a href="/services" class="inline-flex items-center justify-center mt-4 text-primary hover:text-orange transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>
        <!-- Feature 2: Trophy icon -->
        <div>
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
          </div>
          <h3 class="font-sans text-[34px] leading-tight font-semibold text-primary mb-3">{t("services_feature_2_title")}</h3>
          <p class="text-sm text-muted-foreground max-w-sm mx-auto">{t("services_feature_2_desc")}</p>
          <a href="/services" class="inline-flex items-center justify-center mt-4 text-primary hover:text-orange transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>
        <!-- Feature 3: Settings2 icon -->
        <div>
          <div class="w-14 h-14 mx-auto mb-4 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange"><path d="M20 7h-9"></path><path d="M14 17H5"></path><circle cx="17" cy="17" r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg>
          </div>
          <h3 class="font-sans text-[34px] leading-tight font-semibold text-primary mb-3">{t("services_feature_3_title")}</h3>
          <p class="text-sm text-muted-foreground max-w-sm mx-auto">{t("services_feature_3_desc")}</p>
          <a href="/services" class="inline-flex items-center justify-center mt-4 text-primary hover:text-orange transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4 lg:px-8">
        <p class="text-center text-[10px] font-bold tracking-[0.24em] text-muted-foreground uppercase mb-3">PEOPLE SAY ABOUT US</p>
        <h2 class="text-center font-sans text-[48px] md:text-[68px] leading-[0.95] font-semibold text-[#10275c] mb-12">Our customers say</h2>
      </div>
      {testimonials.length > 0 ? (
        <>
          <div class="container mx-auto px-4 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 justify-items-center">
              {testimonials.map((item: any) => (
                <div class="w-full max-w-[420px] bg-[#f4f5f7] p-8">
                  <div class="flex gap-1 mb-4">
                    {Array.from({ length: item.rating || 0 }).map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    ))}
                  </div>
                  <p class="text-sm text-[#58657f] leading-7 mb-6">{item.content}</p>
                  <p class="font-sans font-semibold text-[21px] text-primary">{item.name}</p>
                  <p class="text-xs text-muted-foreground">{item.company}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="flex justify-center gap-2 mt-8">
            <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
            <span class="w-1.5 h-1.5 rounded-full bg-[#c7cfdb]"></span>
            <span class="w-1.5 h-1.5 rounded-full bg-[#c7cfdb]"></span>
            <span class="w-1.5 h-1.5 rounded-full bg-[#c7cfdb]"></span>
            <span class="w-1.5 h-1.5 rounded-full bg-[#c7cfdb]"></span>
          </div>
        </>
      ) : (
        <div class="container mx-auto px-4 lg:px-8">
          <p class="text-center text-[#7b879f] text-sm">Testimonials will appear here soon.</p>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
