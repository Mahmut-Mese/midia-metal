---
import BaseLayout from '@/layouts/BaseLayout.astro';
import QuoteForm from '@/islands/QuoteForm';
---

<BaseLayout
  title="Get a Quote"
  description="Request a free quote for custom stainless steel fabrication, kitchen canopy systems, and more from Midia M Metal."
  canonicalPath="/get-a-quote"
>
  <div class="min-h-screen bg-[#eaf0f3]">
    <section class="container mx-auto px-4 lg:px-8 pt-16 md:pt-24 pb-20 md:pb-28 max-w-3xl">
      <QuoteForm client:visible />
    </section>
  </div>
</BaseLayout>
