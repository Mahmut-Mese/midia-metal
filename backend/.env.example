APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SHIPPING_PROVIDER=easypost
SHIPPING_MOCK=true
SHIPPING_FROM_NAME="${APP_NAME}"
SHIPPING_FROM_COMPANY="Midia Metal"
SHIPPING_FROM_EMAIL="info@midia-metal.com"
SHIPPING_FROM_PHONE="+44 123 456 7890"
SHIPPING_FROM_ADDRESS_LINE1="Unit 8A Cromwell Centre"
SHIPPING_FROM_ADDRESS_LINE2="Roebuck Road, Hainault Business Park"
SHIPPING_FROM_CITY="Ilford"
SHIPPING_FROM_POSTCODE="IG6 3UG"
SHIPPING_FROM_COUNTRY=GB
SHIPPING_DEFAULT_RATE=6.50
SHIPPING_DEFAULT_LENGTH=30
SHIPPING_DEFAULT_WIDTH=20
SHIPPING_DEFAULT_HEIGHT=10
SHIPPING_DEFAULT_DISTANCE_UNIT=cm
SHIPPING_DEFAULT_WEIGHT=2
SHIPPING_DEFAULT_MASS_UNIT=kg
SHIPPING_PACKAGE_PADDING_CM=1
SHIPPING_PACKAGE_TARE_WEIGHT_KG=0.15
SHIPPING_MAX_PARCEL_WEIGHT_KG=25
SHIPPING_MAX_PARCEL_LENGTH_CM=100
SHIPPING_MAX_LENGTH_PLUS_GIRTH_CM=300
EASYPOST_API_KEY=
EASYPOST_DEFAULT_CARRIER="Royal Mail"
EASYPOST_DEFAULT_SERVICE="Tracked 48"
EASYPOST_WEBHOOK_SECRET=
EASYPOST_WEBHOOK_TOLERANCE_MINUTES=5

FRONTEND_DEPLOY_TRIGGER_ENABLED=false
GITHUB_ACTIONS_TRIGGER_TOKEN=
GITHUB_ACTIONS_REPOSITORY=Mahmut-Mese/midia-metal
GITHUB_FRONTEND_DEPLOY_WORKFLOW=frontend-content-deploy.yml
GITHUB_FRONTEND_DEPLOY_REF=staging
FRONTEND_DEPLOY_DEBOUNCE_SECONDS=60
GITHUB_API_BASE=https://api.github.com
